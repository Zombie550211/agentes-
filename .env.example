# ═══════════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO - Connecting CRM Dashboard
#  
#  Copia este archivo a .env y configura tus valores reales
# ═══════════════════════════════════════════════════════════════

# ─── MONGODB ───
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/crmagente?retryWrites=true&w=majority
MONGODB_URI_LOCAL=mongodb://localhost:27017/crmagente_local
MONGODB_DBNAME=crmagente

# ─── JWT ───
JWT_SECRET=aklsjdlkasjdlasdasdasdaskasjdlkasjdjasdkjsalkdjaslkjdlkas
JWT_EXPIRE=7d

# ─── SERVIDOR ───
PORT=5000
NODE_ENV=production

# ─── EMAIL (SMTP) - Para recuperación de contraseña ───
# Servidor SMTP de DirectV Deals
EMAIL_HOST=smtp.directvdeals.net
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=dperez@directvdeals.net
EMAIL_PASS=tu_contraseña_smtp_aqui

# Tiempo de expiración del código de verificación (en minutos)
RESET_CODE_EXPIRY_MINUTES=10

# ─── CLOUDINARY (Opcional - para multimedia) ───
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── SEGURIDAD ───
# TLS inseguro solo para desarrollo local
TLS_INSECURE=0

# Timeouts de MongoDB (en milisegundos)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=20000
MONGODB_CONNECT_TIMEOUT_MS=20000
MONGODB_SOCKET_TIMEOUT_MS=45000
