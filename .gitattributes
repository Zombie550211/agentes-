# Forzar LF en todos los archivos de texto del proyecto
* text=auto eol=lf

# Código fuente — siempre LF
*.py    text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.txt   text eol=lf
*.env   text eol=lf

# Archivos de configuración
.editorconfig   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
Dockerfile      text eol=lf

# Binarios — no tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
